# ============================================================
# vibe-iterator — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# Required: Primary test account credentials
# Use a dedicated test account — never your production account
# ------------------------------------------------------------
VIBE_ITERATOR_TEST_EMAIL=test@example.com
VIBE_ITERATOR_TEST_PASSWORD=testpassword123

# ------------------------------------------------------------
# Required: Target application URL
# Can also be set via --target CLI flag (CLI overrides this)
# ------------------------------------------------------------
VIBE_ITERATOR_TARGET=http://localhost:3000

# ------------------------------------------------------------
# Optional: Dashboard GUI port (default: 3001)
# ------------------------------------------------------------
VIBE_ITERATOR_PORT=3001

# ------------------------------------------------------------
# Optional: Supabase project details
# Enables deeper Supabase-specific scanning (RLS, buckets, tiers)
# Leave blank to rely on auto-detection from network traffic
# ------------------------------------------------------------
VIBE_ITERATOR_SUPABASE_URL=https://your-project.supabase.co
VIBE_ITERATOR_SUPABASE_ANON_KEY=eyJ...

# ------------------------------------------------------------
# Optional: Second test account for cross-user testing
# Enables IDOR and RLS cross-user checks in rls_bypass and auth_check
# Both email and password must be set, or both left blank
# ------------------------------------------------------------
VIBE_ITERATOR_TEST_EMAIL_2=test2@example.com
VIBE_ITERATOR_TEST_PASSWORD_2=testpassword456
