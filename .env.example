# ============================================================
# vibe-iterator — Environment Variables
# ============================================================
#
# SETUP (3 steps):
#   1. cp .env.example .env
#   2. Fill in your test account and target URL below
#   3. Run: vibe-iterator
#
# Rules:
#   - NEVER commit .env to git (it's already in .gitignore)
#   - Use a DEDICATED TEST ACCOUNT — never your personal login
#   - VIBE_ITERATOR_TARGET is the URL Selenium browses (frontend)
#   - VIBE_ITERATOR_BACKEND_URL is where your API lives (if different)
#
# ============================================================


# ============================================================
# STEP 1 — Who to log in as
# ============================================================
# Create a test account in your app just for security scanning.
# This account will be used to log in, crawl, and tamper.
# ------------------------------------------------------------
VIBE_ITERATOR_TEST_EMAIL=test@yourapp.com
VIBE_ITERATOR_TEST_PASSWORD=your-test-password


# ============================================================
# STEP 2 — Where your app is
# ============================================================
# VIBE_ITERATOR_TARGET — the frontend URL Selenium will browse.
# This is also used as the Origin header for API probes.
#
# For local dev:
#   VIBE_ITERATOR_TARGET=http://localhost:3000
#
# For production / staging:
#   VIBE_ITERATOR_TARGET=https://www.yourapp.com
# ------------------------------------------------------------
VIBE_ITERATOR_TARGET=http://localhost:3000

# VIBE_ITERATOR_BACKEND_URL — set this ONLY when your backend API
# runs on a different origin than your frontend.
#
# Common case (same origin — Next.js full-stack, single server):
#   Leave this blank. Scanners probe VIBE_ITERATOR_TARGET directly.
#
# Split origin (Next.js frontend + separate Express/FastAPI backend):
#   VIBE_ITERATOR_TARGET=http://localhost:3000      ← frontend (Selenium)
#   VIBE_ITERATOR_BACKEND_URL=http://localhost:4000 ← backend API (scanners)
#
# Production split:
#   VIBE_ITERATOR_TARGET=https://www.yourapp.com
#   VIBE_ITERATOR_BACKEND_URL=https://api.yourapp.com
# ------------------------------------------------------------
VIBE_ITERATOR_BACKEND_URL=


# ============================================================
# STEP 3 — Optional but recommended
# ============================================================

# Supabase — enables RLS bypass, bucket limits, tier escalation checks.
# Leave blank if you're not on Supabase (auto-detection still works).
VIBE_ITERATOR_SUPABASE_URL=https://your-project.supabase.co
VIBE_ITERATOR_SUPABASE_ANON_KEY=eyJ...

# Second test account — enables IDOR and cross-user RLS checks.
# Both must be set together, or both left blank.
VIBE_ITERATOR_TEST_EMAIL_2=test2@yourapp.com
VIBE_ITERATOR_TEST_PASSWORD_2=your-second-test-password


# ============================================================
# Advanced — only change if you know what you're doing
# ============================================================

# Dashboard port (default: 3001 → http://localhost:3001)
VIBE_ITERATOR_PORT=3001

# Chrome remote debugging port (0 = auto-pick a free port)
VIBE_ITERATOR_CHROME_DEBUG_PORT=0

# Set to 1 only for isolated local experiments — bypasses Chrome
# security model, never use against real user data.
VIBE_ITERATOR_DISABLE_WEB_SECURITY=0
